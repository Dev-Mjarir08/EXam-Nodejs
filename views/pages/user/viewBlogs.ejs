<!DOCTYPE html>
<html>
<head>
    <title>Blogs</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5">

<h2>All Blogs</h2>

<a href="/user/addBlog" class="btn btn-success mb-3">Add Blog</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>#</th>
            <th>Title</th>
            <th>Content</th>
            <th>Image</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        <% blogs.forEach((blog, index) => { %>
            <tr>
                <td><%= index + 1 %></td>
                <td><%= blog.title %></td>
                <td><%= blog.content?.substring(0,50) %></td>

                <td>
                    <% if(blog.image){ %>
                        <img src="/<%= blog.image %>" width="60">
                    <% } %>
                </td>

                <td>
                    <a href="/user/editBlog/<%= blog._id %>" class="btn btn-warning">Edit</a>
                    <a href="/user/deleteBlog/<%= blog._id %>" class="btn btn-danger">Delete</a>
                </td>
            </tr>
        <% }) %>
    </tbody>
</table>

</body>
</html>